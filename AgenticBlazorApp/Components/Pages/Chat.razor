@page "/"
@page "/chat"
@rendermode InteractiveServer
@using Markdig
@inject ChatService ChatSvc
@inject AlertService Alerts
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Agentic Kernel</PageTitle>

<div class="shell">

    <header class="topbar">
        <div class="brand">
            <span class="brand-dot"></span>
            <span class="brand-name">Agentic <em>Kernel</em></span>
        </div>
        <div class="topbar-right">
            <a class="ghost-link" href="/hangfire" target="_blank" rel="noopener">Hangfire ↗</a>
            <button class="ghost-btn" title="Clear conversation"
                    @onclick="Reset" disabled="@(_waiting || ChatSvc.IsEmpty)">
                Clear
            </button>
        </div>
    </header>

    <main id="chat-window" class="stream">

        @if (ChatSvc.IsEmpty && !_waiting)
        {
            <section class="welcome">
                <div class="glyph">/ /</div>
                <h1>How can I help?</h1>
                <p class="welcome-sub">Ask anything. I can read the web, work your inbox, schedule jobs.</p>
                <div class="suggestions">
                    <button @onclick='@(() => QuickSend("Summarise what you can do in a bulleted list with code examples for each tool group."))'>
                        <span>Show me what you can do</span>
                    </button>
                    <button @onclick='@(() => QuickSend("Read me the BBC news."))'>
                        <span>Read the BBC news</span>
                    </button>
                    <button @onclick='@(() => QuickSend("Summarise https://news.ycombinator.com and give me the top 3 items as a markdown list."))'>
                        <span>Summarise Hacker News</span>
                    </button>
                    <button @onclick='@(() => QuickSend("Every 10 minutes, check for new emails in my work inbox and summarise them."))'>
                        <span>Every 10 min: check my work inbox</span>
                    </button>
                </div>
            </section>
        }

        @foreach (var m in ChatSvc.VisibleMessages)
        {
            var isUser = m.Role == AuthorRole.User;
            <article class="msg @(isUser ? "user" : "assistant")">
                <div class="avatar">@(isUser ? "You" : "AI")</div>
                <div class="bubble">
                    <div class="md">@((MarkupString)RenderMarkdown(m.Content))</div>
                </div>
            </article>
        }

        @if (_waiting)
        {
            <article class="msg assistant">
                <div class="avatar">AI</div>
                <div class="bubble typing">
                    <span></span><span></span><span></span>
                </div>
            </article>
        }

    </main>

    <footer class="composer">
        <div class="composer-inner">
            <textarea class="composer-input"
                      rows="1"
                      placeholder="Message the agent…  ⏎ to send · Shift+⏎ for newline"
                      @bind="_input"
                      @bind:event="oninput"
                      @onkeydown="OnKey"
                      disabled="@_waiting"></textarea>
            <button class="send" title="Send"
                    @onclick="Send"
                    disabled="@(_waiting || string.IsNullOrWhiteSpace(_input))">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="19" x2="12" y2="5"/>
                    <polyline points="5 12 12 5 19 12"/>
                </svg>
            </button>
        </div>
        <div class="composer-hint">Markdown rendered · Enter to send · Shift+Enter newline</div>
    </footer>

</div>

@code {
    private string _input = string.Empty;
    private bool _waiting;

    // Markdig pipeline: advanced extensions (tables, task lists, autolinks, etc.)
    // DisableHtml strips raw <script>/<iframe>/etc. from the incoming markdown.
    private static readonly MarkdownPipeline _pipe =
        new MarkdownPipelineBuilder()
            .UseAdvancedExtensions()
            .UseSoftlineBreakAsHardlineBreak()
            .DisableHtml()
            .Build();

    private static string RenderMarkdown(string? src) =>
        string.IsNullOrEmpty(src) ? "" : Markdown.ToHtml(src, _pipe);

    protected override void OnInitialized()
    {
        ChatSvc.Changed += OnChanged;
        Alerts.Fired += OnAlertFired;
    }

    private async void OnChanged()
    {
        await InvokeAsync(async () =>
        {
            StateHasChanged();
            await ScrollToBottom();
        });
    }

    private async void OnAlertFired(AlertNotification n)
    {
        // ChatService already injects the alert into the chat stream;
        // we just fire a browser notification in case the user is on
        // another tab.  Swallow all exceptions — the circuit might be
        // mid-reconnect, and JS interop will just fail gracefully.
        await InvokeAsync(async () =>
        {
            try { await JS.InvokeVoidAsync("appNotify.show", n.Title, n.Body); } catch { }
        });
    }

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (first)
        {
            try { await JS.InvokeVoidAsync("appNotify.ensurePermission"); } catch { }
            await ScrollToBottom();
        }
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(_input) || _waiting) return;
        var msg = _input.Trim();
        _input = string.Empty;
        _waiting = true;
        StateHasChanged();
        try { await ChatSvc.SendAsync(msg); }
        finally
        {
            _waiting = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    private async Task QuickSend(string text)
    {
        if (_waiting) return;
        _input = text;
        await Send();
    }

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await Send();
        }
    }

    private void Reset() => ChatSvc.Reset();

    private async Task ScrollToBottom()
    {
        try { await JS.InvokeVoidAsync("chatScroll.toBottom", "chat-window"); }
        catch { /* circuit not ready */ }
    }

    public void Dispose()
    {
        ChatSvc.Changed -= OnChanged;
        Alerts.Fired -= OnAlertFired;
    }
}
